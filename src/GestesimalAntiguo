
import Modelo.Articulo;
import Modelo.Cliente;

import java.util.ArrayList;
import java.util.Scanner;

/*
Crea el programa GESTISIMAL (GESTIón SIMplificada de Almacén) para llevar el control
de los artículos de un almacén. De cada artículo se debe saber el código, la descripción, el
precio de compra, el precio de venta y el stock (número de unidades). El menú del programa
debe tener, al menos, las siguientes opciones:
1. Listado
2. Alta
3. Baja
4. Modificación
5. Entrada de mercancía
6. Salida de mercancía
7. Salir
La entrada y salida de mercancía supone respectivamente el incremento y decremento de
stock de un determinado artículo. Hay que controlar que no se pueda sacar más mercancía
de la que hay en el almacén.
 */
public class Gestisimal {
    final static Scanner s = new Scanner(System.in);

    public static void main(String[] args) {
        gestionGESTESIMAL controlador = new gestionGESTESIMAL();
        ArrayList<Cliente> clientes = controlador.getClientes();
        boolean menuOff = false;
        int option;
        addMock(listaArticulos);

        System.out.println("Bienvenido a GESTISIMAL");
        do {
            System.out.println("\n\nActualmente tenemos: " + listaArticulos.size() + " artículos dados de alta");
            System.out.println("El stock total de todos los artículos es: " + stockTotal(listaArticulos));
            System.out.println("\n-------------------------------");
            System.out.println("1 -> Listado");
            System.out.println("2 -> Alta");
            System.out.println("3 -> Baja");
            System.out.println("4 -> Modificación");
            System.out.println("5 -> Entrada de mercancía");
            System.out.println("6 -> Salida de mercancía");
            System.out.println("7 -> Salir");
            System.out.println("--------------------------------");
            System.out.print("Introduce una opción: ");
            option = Integer.parseInt(s.nextLine());
            switch (option) {
                case 1: //Listado de todos los artículos
                    if (listaArticulos.isEmpty()) System.out.println("Todavia no hay ningun producto registrado");
                    else {
                        for (Articulo a : listaArticulos) {
                            System.out.println(a);
                        }
                    }
                    break;
                case 2:
                    System.out.print("Introduce la descripción del artículo: ");
                    String descripcion = s.nextLine();
                    System.out.print("Introduce el precio de compra: ");
                    float precioCompra = Float.parseFloat(s.nextLine());
                    System.out.print("Introduce el precio de venta: ");
                    float precioVenta = Float.parseFloat(s.nextLine());

                    listaArticulos.add(new Articulo(generaCodigo(listaArticulos), descripcion, precioCompra, precioVenta));
                    System.out.println("Artículo registrado correctamente. ");
                    break;
                case 3:
                    System.out.print("Introduce el código del artículo: ");
                    String codigo = s.nextLine();
                    if (buscaCodigo(listaArticulos, codigo) == null) System.out.println("El código no corresponde a ningún artículo. ");
                    else {
                        listaArticulos.remove(buscaCodigo(listaArticulos, codigo));
                        System.out.println("Artículo eliminado con éxito.");
                    }
                    break;
                case 4:
                    System.out.print("Introduce el código del artículo: ");
                    codigo = s.nextLine();
                    Articulo temp = buscaCodigo(listaArticulos,codigo);
                    if (temp == null) System.out.println("No se ha encontrado el artículo");
                    else {
                        System.out.print("Introduce la descripción del artículo: ");
                        temp.setDescripcion(s.nextLine());
                        System.out.print("Introduce el precio de compra: ");
                        temp.setPrecioCompra(Float.parseFloat(s.nextLine()));
                        System.out.print("Introduce el precio de venta: ");
                        temp.setPrecioVenta(Float.parseFloat(s.nextLine()));
                        System.out.println("Artículo modificado con éxito");
                    }
                    break;
                case 5:
                    System.out.print("Introduce el código del artículo: ");
                    codigo = s.nextLine();
                    temp = buscaCodigo(listaArticulos,codigo);
                    if (temp == null) System.out.println("No se ha encontrado el artículo");
                    else {
                        System.out.println("Introduce la cantidad de stock que deseas añadir");
                        int stock = Integer.parseInt(s.nextLine());
                        if (stock>0) temp.addStock(stock);
                        System.out.println("Stock añadido correctamente. El nuevo stock es " + temp.getStock());
                    }
                    break;
                case 6:
                    System.out.print("Introduce el código del artículo: ");
                    codigo = s.nextLine();
                    temp = buscaCodigo(listaArticulos,codigo);
                    if (temp == null) System.out.println("No se ha encontrado el artículo");
                    else {
                        System.out.println("Introduce la cantidad de stock que desea retirar: ");
                        int unidades = Integer.parseInt(s.nextLine());
                        if (temp.deleteStock(unidades)){
                            System.out.println("El importe de la factura es: "+temp.calculaPrecioVentaTotal(unidades));
                            System.out.println("Stock modificado con éxito");
                            System.out.println("La ganancia ha sido de: "+temp.calculaGananciaVenta(unidades)+" €");
                        }else System.out.println("Error al modificar el stock");
                    }
                    break;
                case 7:
                    menuOff = true;
                    break;
                default:
                    System.out.println("La opcion no es valida");
                    break;
            }
        } while (!menuOff);
    }


    protected static String generaCodigo(ArrayList<Articulo> lista) {
        String[] abc = {"a", "b", "c", "d", "e", "f", "g", "h", "i", "j"};
        String resultado = "";
        int longitudClave = 6;
        do {
            for (int i = 0; i < longitudClave; i -= -1) {
                if ((int) (Math.random() * 2) == 0) {
                    resultado += (int) (Math.random() * 10);
                } else resultado += abc[(int) (Math.random() * 10)];
            }
        }while (buscaCodigo(lista, resultado) != null);
        return resultado;
    }

    public static Articulo buscaCodigo(ArrayList<Articulo> lista, String codigo) {
        for (Articulo a : lista) {
            if (a.getCodigo().equalsIgnoreCase(codigo)) return a;
        }
        return null;
    }

    public static int stockTotal(ArrayList<Articulo> lista) {
        int total = 0;
        for (Articulo a : lista) {
            total += a.getStock();
        }
        return total;
    }


    public static void addMock(ArrayList<Articulo> lista) {
        lista.add(new Articulo(generaCodigo(lista), "Iphone 11", 1234.56f, 3254.25f));
        lista.add(new Articulo(generaCodigo(lista), "TV LG", 4234.56f, 3213254.25f));
        lista.add(new Articulo(generaCodigo(lista), "Mac de Flavio", 234.56f, 2324.25f));
        lista.add(new Articulo(generaCodigo(lista), "Raton inalambrico", 1234.56f, 45254.25f));
    }
}
